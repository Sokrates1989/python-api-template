"""PostgreSQL repository for generated subject-owned records."""

from __future__ import annotations

from collections.abc import Callable
from typing import Any

from sqlalchemy import delete, func, select

from apps.__APP_ID__.models.record import Record
from backend.database.factory import get_database_handler
from backend.database.sql_handler import SQLHandler


class RecordRevisionConflict(Exception):
    """Report an optimistic revision mismatch without exposing another owner.

    Attributes:
        current_revision: Latest revision visible to the authenticated owner.
    """

    def __init__(self, current_revision: int) -> None:
        """Store the current revision.

        Args:
            current_revision: Latest database revision for the owned record.
        """

        self.current_revision = current_revision
        super().__init__("record revision conflict")


class RecordsRepository:
    """Own SQL persistence operations for one generated records table."""

    def __init__(self, handler_factory: Callable[[], Any] = get_database_handler) -> None:
        """Resolve the selected SQL handler lazily.

        Args:
            handler_factory: Callable returning the configured database handler.

        Raises:
            RuntimeError: If the selected backend is not SQL based.
        """

        handler = handler_factory()
        if not isinstance(handler, SQLHandler):
            raise RuntimeError("records starter requires the PostgreSQL backend profile")
        self._handler = handler

    async def list_for_owner(
        self, owner_subject: str, *, limit: int, offset: int
    ) -> tuple[list[Record], int]:
        """Return a stable page and total count for one verified subject.

        Args:
            owner_subject: Verified identity-provider subject.
            limit: Maximum rows returned.
            offset: Number of matching rows skipped.

        Returns:
            Records ordered newest-first and the owner's total row count.
        """

        async with self._handler.AsyncSessionLocal() as session:
            rows = await session.execute(
                select(Record)
                .where(Record.owner_subject == owner_subject)
                .order_by(Record.updated_at.desc(), Record.id.asc())
                .limit(limit)
                .offset(offset)
            )
            total = await session.scalar(
                select(func.count()).select_from(Record).where(
                    Record.owner_subject == owner_subject
                )
            )
        return list(rows.scalars().all()), int(total or 0)

    async def create(self, record: Record) -> Record:
        """Persist and refresh a new owned record.

        Args:
            record: Unsaved record with a generated UUID.

        Returns:
            Persisted record including database timestamps.
        """

        async with self._handler.AsyncSessionLocal() as session:
            session.add(record)
            await session.commit()
            await session.refresh(record)
        return record

    async def get_for_owner(self, owner_subject: str, record_id: str) -> Record | None:
        """Return one owned record without revealing cross-owner existence.

        Args:
            owner_subject: Verified identity-provider subject.
            record_id: Public record UUID.

        Returns:
            Owned record, or ``None`` for missing and foreign records.
        """

        async with self._handler.AsyncSessionLocal() as session:
            result = await session.execute(
                select(Record).where(
                    Record.id == record_id,
                    Record.owner_subject == owner_subject,
                )
            )
        return result.scalar_one_or_none()

    async def update_for_owner(
        self,
        owner_subject: str,
        record_id: str,
        *,
        title: str,
        details: str | None,
        expected_revision: int,
    ) -> Record | None:
        """Update an owned row under a transactional revision lock.

        Args:
            owner_subject: Verified identity-provider subject.
            record_id: Public record UUID.
            title: Replacement bounded title.
            details: Replacement optional details.
            expected_revision: Revision observed by the caller.

        Returns:
            Updated record, or ``None`` when absent or foreign.

        Raises:
            RecordRevisionConflict: If the caller revision is stale.
        """

        async with self._handler.AsyncSessionLocal() as session:
            async with session.begin():
                result = await session.execute(
                    select(Record)
                    .where(Record.id == record_id, Record.owner_subject == owner_subject)
                    .with_for_update()
                )
                record = result.scalar_one_or_none()
                if record is None:
                    return None
                if record.revision != expected_revision:
                    raise RecordRevisionConflict(record.revision)
                record.title = title
                record.details = details
                record.revision += 1
                record.updated_at = func.now()
            await session.refresh(record)
        return record

    async def delete_for_owner(self, owner_subject: str, record_id: str) -> bool:
        """Idempotently delete an owned row without cross-owner disclosure.

        Args:
            owner_subject: Verified identity-provider subject.
            record_id: Public record UUID.

        Returns:
            ``True`` when a row was removed; otherwise ``False``.
        """

        async with self._handler.AsyncSessionLocal() as session:
            result = await session.execute(
                delete(Record).where(
                    Record.id == record_id,
                    Record.owner_subject == owner_subject,
                )
            )
            await session.commit()
        return bool(result.rowcount)
