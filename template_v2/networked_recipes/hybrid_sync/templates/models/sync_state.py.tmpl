"""SQLAlchemy state for generated owner-scoped record synchronization."""

from __future__ import annotations

from datetime import datetime
from typing import Any

from sqlalchemy import BigInteger, Boolean, DateTime, Index, Integer, JSON, String, UniqueConstraint
from sqlalchemy.orm import Mapped, mapped_column

from models.sql.base import Base


class SyncEntity(Base):
    """Persist the latest server state for one subject-owned neutral record.

    Attributes:
        owner_subject: Verified identity-provider subject owning the entity.
        entity_type: Bounded neutral entity contract, currently ``record``.
        entity_id: Stable app-owned record identifier.
        version: Monotonic server version used for optimistic concurrency.
        payload: Latest JSON object, or null for a retained tombstone.
        deleted: Whether the entity is a retained deletion tombstone.
        updated_at: UTC time assigned when the server accepted the change.
    """

    __tablename__ = "__APP_ID___sync_entities"
    __table_args__ = (
        Index("ix___APP_ID___sync_entity_owner_updated", "owner_subject", "updated_at"),
    )

    owner_subject: Mapped[str] = mapped_column(String(255), primary_key=True)
    entity_type: Mapped[str] = mapped_column(String(48), primary_key=True)
    entity_id: Mapped[str] = mapped_column(String(128), primary_key=True)
    version: Mapped[int] = mapped_column(Integer, nullable=False)
    payload: Mapped[dict[str, Any] | None] = mapped_column(JSON, nullable=True)
    deleted: Mapped[bool] = mapped_column(Boolean, nullable=False, default=False)
    updated_at: Mapped[datetime] = mapped_column(DateTime(timezone=True), nullable=False)


class SyncChange(Base):
    """Persist one immutable owner-scoped change-feed entry.

    Attributes:
        sequence: Monotonic database sequence used only inside opaque cursors.
        owner_subject: Verified subject allowed to pull the change.
        entity_type: Neutral synchronized entity contract.
        entity_id: Stable app-owned record identifier.
        version: Accepted server version.
        payload: Accepted JSON object, or null for deletion.
        deleted: Whether the entry represents a deletion tombstone.
        updated_at: UTC server acceptance time.
    """

    __tablename__ = "__APP_ID___sync_changes"
    __table_args__ = (
        Index("ix___APP_ID___sync_change_owner_sequence", "owner_subject", "sequence"),
    )

    sequence: Mapped[int] = mapped_column(BigInteger, primary_key=True, autoincrement=True)
    owner_subject: Mapped[str] = mapped_column(String(255), nullable=False)
    entity_type: Mapped[str] = mapped_column(String(48), nullable=False)
    entity_id: Mapped[str] = mapped_column(String(128), nullable=False)
    version: Mapped[int] = mapped_column(Integer, nullable=False)
    payload: Mapped[dict[str, Any] | None] = mapped_column(JSON, nullable=True)
    deleted: Mapped[bool] = mapped_column(Boolean, nullable=False)
    updated_at: Mapped[datetime] = mapped_column(DateTime(timezone=True), nullable=False)


class SyncOperation(Base):
    """Persist an idempotent push result for one owner and operation id.

    Attributes:
        id: Internal database identity.
        owner_subject: Verified subject that first used the operation id.
        operation_id: Client-stable replay identity within the owner scope.
        request_sha256: Digest detecting same-id/different-request collisions.
        result: Stable previously returned response payload.
        created_at: UTC server acceptance time.
    """

    __tablename__ = "__APP_ID___sync_operations"
    __table_args__ = (
        UniqueConstraint(
            "owner_subject",
            "operation_id",
            name="uq___APP_ID___sync_operation_owner_id",
        ),
        Index("ix___APP_ID___sync_operation_owner", "owner_subject"),
    )

    id: Mapped[int] = mapped_column(BigInteger, primary_key=True, autoincrement=True)
    owner_subject: Mapped[str] = mapped_column(String(255), nullable=False)
    operation_id: Mapped[str] = mapped_column(String(96), nullable=False)
    request_sha256: Mapped[str] = mapped_column(String(64), nullable=False)
    result: Mapped[dict[str, Any]] = mapped_column(JSON, nullable=False)
    created_at: Mapped[datetime] = mapped_column(DateTime(timezone=True), nullable=False)
