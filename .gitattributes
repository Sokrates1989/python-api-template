* text=auto

# Keep shell scripts executable and LF-normalized.
*.sh text eol=lf

# Keep PowerShell scripts Windows-friendly.
*.ps1 text eol=crlf

# Source and config defaults.
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.md text eol=lf
*.lock text eol=lf

# Env files must stay LF so Bash variable readers don't receive trailing CR.
.env text eol=lf
.env.* text eol=lf
